# ─────────────────────────────────────────────────────────────
# Northwind Refund Agent — environment configuration
# Copy this file to ".env" and fill in your keys.
# ─────────────────────────────────────────────────────────────

# REQUIRED — Anthropic Platform API key (separate from a Claude.ai / Claude Code
# subscription). Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Model the agent uses. Default is the most capable Opus tier.
# Faster/cheaper alternative for live chat/voice: claude-sonnet-4-6
AGENT_MODEL=claude-opus-4-8

# Reasoning effort: low | medium | high | max
# "medium" balances latency and rigor for interactive chat. Use "high" to
# maximize policy-reasoning quality (the "holding the line" cases).
AGENT_EFFORT=medium

# Simulate a flaky payment gateway: the first charge attempt for any order
# fails with a transient error so you can SEE the agent's retry logic in the
# reasoning logs. Set to "false" for a perfectly reliable gateway.
FLAKY_GATEWAY=true

# OPTIONAL — ElevenLabs for premium text-to-speech in the voice demo.
# Without this, voice replies fall back to the browser's built-in speech engine.
# Get a key at https://elevenlabs.io  (free tier works)
ELEVENLABS_API_KEY=
# Default voice "Rachel". Override with any ElevenLabs voice ID.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Server port (the web dev server proxies /api to this).
PORT=8787
